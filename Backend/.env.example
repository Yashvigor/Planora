# =============================================================================
# Planora Backend - Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env   (Mac/Linux)
#   copy .env.example .env (Windows)
# =============================================================================

# --- Server Configuration ---
PORT=5000
NODE_ENV=development

# --- Database (Neon PostgreSQL) ---
# Get these from your Neon dashboard: https://console.neon.tech
DB_USER=your_neon_username
DB_HOST=your-neon-host.neon.tech
DB_NAME=your_database_name
DB_PASSWORD=your_neon_password
DB_PORT=5432
PGSSLMODE=require

# Full connection string (used by auth middleware)
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://your_neon_username:your_neon_password@your-neon-host.neon.tech/your_database_name?sslmode=require

# --- Authentication ---
JWT_SECRET=generate-a-secure-random-string-here
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# --- Email (Brevo SMTP) ---
# Get these from your Brevo dashboard: https://app.brevo.com/settings/keys/smtp
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_login
SMTP_PASS=your_brevo_smtp_password
SENDER_EMAIL=your_verified_sender@example.com

# --- Frontend URL (for email links) ---
# In development: http://localhost:5173
# In production: https://your-deployed-frontend.com
FRONTEND_URL=http://localhost:5173

# --- CORS ---
# Comma-separated list of allowed origins, or * for development
# In production, restrict to your deployed frontend domain
CORS_ORIGIN=http://localhost:5173
